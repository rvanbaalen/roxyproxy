{
  "name": "@rvanbaalen/roxyproxy",
  "version": "0.1.0",
  "description": "HTTP/HTTPS intercepting proxy with CLI and web UI",
  "type": "module",
  "bin": {
    "roxyproxy": "./dist/cli/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build:server": "tsc -p tsconfig.server.json",
    "build:ui": "vite build",
    "build": "npm run build:server && npm run build:ui",
    "dev:ui": "vite",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rvanbaalen/roxyproxy.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public"
  },
  "license": "MIT",
  "dependencies": {
    "@phosphor-icons/react": "^2.1.10",
    "better-sqlite3": "^12.8.0",
    "commander": "^14.0.3",
    "express": "^5.2.1",
    "ink": "^6.8.0",
    "ink-select-input": "^6.2.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "node-forge": "^1.3.3",
    "picocolors": "^1.1.1",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "@types/node-forge": "^1.3.14",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "vite": "^8.0.0",
    "vitest": "^4.1.0"
  }
}
